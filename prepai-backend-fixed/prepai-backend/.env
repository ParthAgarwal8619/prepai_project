# ── PrepAI Backend - Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values

# Gemini API Key (get from: https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSyCi6Um5c8PsYDh_ahDnGIN2d4iPfBtpGc4

# Gemini model (optional – defaults to gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# MongoDB connection string (defaults to local)
MONGO_URI=mongodb://localhost:27017

# Database name
DB_NAME=prepai

# Server settings
HOST=0.0.0.0
PORT=8000

# Tesseract path (Windows only – needed for scanned PDF OCR)
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
